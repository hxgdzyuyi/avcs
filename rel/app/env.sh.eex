export PHX_SERVER="${PHX_SERVER:-true}"
export AVCS_DESKTOP="${AVCS_DESKTOP:-true}"
export RELEASE_DISTRIBUTION="${RELEASE_DISTRIBUTION:-none}"
export RELEASE_MODE="${RELEASE_MODE:-interactive}"
export RELEASE_COOKIE="${RELEASE_COOKIE:-$(head -c 512 /dev/urandom | env LC_ALL=C tr -dc 'a-zA-Z0-9' | fold -w 32 | head -n 1)}"

cd "$HOME"
